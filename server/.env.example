# Alakir Gallery — server environment
# Copy this file to `.env` and fill in your values.
# DO NOT commit `.env` to git — only this `.env.example`.

# Port the server listens on
PORT=3000

# Optional extra layer of protection: if set, all admin write endpoints
# require a matching value in the `x-admin-token` request header.
# Generate something random with:  openssl rand -hex 24
ADMIN_API_TOKEN=
